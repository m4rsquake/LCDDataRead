  15          //========================================================================
  16          // 函数: PWM_ISR_Handler
  17          // 描述: 15位增强型PWM中断函数.
  18          // 参数: none.
  19          // 返回: none.
  20          // 版本: V1.0, 2020-09-23
  21          //========================================================================
  22          void  PWM_ISR_Handler (void) interrupt PWM_VECTOR
  23          {
  24   1        if(PWMCFG & 0x08)   //PWM计数器中断
  25   1        {
  26   2          PWMCFG &= ~0x08;    //清PWM计数器中断标志
  27   2          // TODO: 在此处添加用户代码
  28   2        }
  29   1        if(PWMIF)   //PWM0匹配中断
  30   1        {
  31   2          PWMIF = 0;
  32   2          // TODO: 在此处添加用户代码
  33   2        }
  34   1      }


