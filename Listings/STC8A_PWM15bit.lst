  59          //========================================================================
  60          // 函数: u8 PWMChannelCtrl(u8 PWM_id, u8 pwm_eno, u8 pwm_ini, u8 pwm_eni, u8 pwm_ent2i, u8 pwm_ent1i)
  61          // 描述: PWM通道控制寄存器设置. 
  62          // 参数: PWM_id: PWM通道序号. 取值 0~7
  63          //       pwm_eno:   pwm输出使能, 0设为GPIO, 1设为PWM输出.
  64          //       pwm_cns:   pwm通道选择, PWM15_SW_P2, PWM15_SW_P1, PWM15_SW_P6.
  65          //       pwm_ini:   pwm输出端的初始电平, 0为低电平, 1为高电平.
  66          //       pwm_eni:   pwm通道中断使能控制, 0为关闭PWM中断, 1为使能PWM中断.
  67          //       pwm_ent2i: pwm通道第二个触发点中断使能控制, 0为关闭PWM第二个触发点中断, 1为使能PWM第二个触发点中断.
  68          //       pwm_ent1i: pwm通道第一个触发点中断使能控制, 0为关闭PWM第一个触发点中断, 1为使能PWM第一个触发点中断.
  69          // 返回: 成功返回 SUCCESS, 错误返回 FAIL.
  70          // 版本: V1.0, 2020-09-22
  71          //========================================================================
  72          u8  PWMChannelCtrl(u8 PWM_id, u8 pwm_eno, u8 pwm_cns, u8 pwm_ini, u8 pwm_eni, u8 pwm_ent2i, u8 pwm_ent1i)
  73          {
  74   1        u8  xdata *pPWMxCR;
  75   1        
  76   1        if(PWM_id > PWM15_7)  return FAIL;  //id错误
  77   1        if(pwm_eno > 1) return FAIL;  //输出使能错误
  78   1        if(pwm_ini > 1) return FAIL;  //输出端的初始电平错误
  79   1        if(pwm_eni > 1) return FAIL;  //中断使能控制错误
  80   1        if(pwm_ent2i > 1) return FAIL;  //第二个触发点中断使能控制错误
  81   1        if(pwm_ent1i > 1) return FAIL;  //第一个触发点中断使能控制错误
  82   1        
  83   1        pPWMxCR = (u8 *)PWMxCR[PWM_id];
  84   1        *pPWMxCR = (pwm_eno << 7) | (pwm_ini << 6) | (pwm_cns << 3) | (pwm_eni << 2) | (pwm_ent2i << 1) | pwm_ent
             -1i;
  85   1        return SUCCESS;
  86   1      }
  87          
  88          //========================================================================
  89          // 函数: u8 PWM15Duty(u8 PWM_id, u16 Period, u16 dutyL, u16 dutyH)
  90          // 描述: PWM 占空比设置. 
  91          // 参数: PWM_id:  PWM通道序号. 取值 0~7
  92          //       dutyL:   pwm输出低电平位置, 取值 0~0x7fff.
  93          //       dutyH:   pwm输出高电平位置, 取值 0~0x7fff.
  94          // 返回: 成功返回 SUCCESS, 错误返回 FAIL.
  95          // 版本: V1.0, 2020-09-22
  96          //========================================================================
  97          u8  PWM15Duty(u8 PWM_id, u16 dutyL, u16 dutyH)
  98          {
  99   1        u16 xdata *pPWMxT1;
 100   1        u16 xdata *pPWMxT2;
 101   1        
 102   1        if(PWM_id > PWM15_7)  return FAIL;  //id错误
 103   1        if(dutyL > 0x7fff)  return FAIL;  //低电平时间设置错误
 104   1        if(dutyH > 0x7fff)  return FAIL;  //高电平时间设置错误
 105   1        
 106   1        pPWMxT1 = (u16 *)PWMxT1[PWM_id];
 107   1        *pPWMxT1 = dutyL & 0x7fff;
 108   1      
 109   1        pPWMxT2 = (u16 *)PWMxT2[PWM_id];
 110   1        *pPWMxT2 = dutyH & 0x7fff;
 111   1        return SUCCESS;
 112   1      }
