 136          //========================================================================
 137          // 函数: u8 PWM15_Init(PWM15_InitTypeDef *PWMx)
 138          // 描述: 15位增强型PWM初始化程序.
 139          // 参数: PWMx: 结构参数,请参考头文件里的定义.
 140          // 返回: 成功返回 SUCCESS, 错误返回 FAIL.
 141          // 版本: V1.0, 2020-09-22
 142          //========================================================================
 143          u8  PWM15_Init(PWM15_InitTypeDef *PWMx)
 144          {
 145   1        PWM15_PWM_Set(PWMx->PWM_Enable);  //使能/关闭 PWM0（包括 PWM00~PWM07）
 146   1        PWM15_PS_Set(PWMx->PWM_Clock_PS); //系统时钟分频参数,  0~15
 147   1        PWM15_Clock_Sel(PWMx->PWM_Clock_Sel); //PWMn时钟源选择
 148   1        PWMC = PWMx->PWM_Period & 0x7fff;
 149   1        PWM15_CounterInt_Set(PWMx->PWM_CInt); //PWMn计数器归零中断使能设置
 150   1        PWM15_Counter_Set(PWMx->PWM_Counter); //PWMn计数器使能设置
 151   1        
 152   1        return SUCCESS;
 153   1      }


