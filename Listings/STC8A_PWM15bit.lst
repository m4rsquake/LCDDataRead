 114          //========================================================================
 115          // 函数: u8 PWMLevelSet(u8 PWM_id, u8 pwm_hldl, u8 pwm_hldh)
C51 COMPILER V9.59.0.0   STC8A_PWM15BIT                                                    12/08/2023 16:39:17 PAGE 3   

 116          // 描述: PWM通道控制寄存器设置. 
 117          // 参数: PWM_id: PWM通道序号. 取值 0~7
 118          //       pwm_hldl:   pwm强制输出低电平控制位, 0正常输出, 1强制输出低电平.
 119          //       pwm_hldh:   pwm强制输出高电平控制位, 0正常输出, 1强制输出高电平.
 120          // 返回: 成功返回 SUCCESS, 错误返回 FAIL.
 121          // 版本: V1.0, 2020-09-22
 122          //========================================================================
 123          u8  PWMLevelSet(u8 PWM_id, u8 pwm_hldl, u8 pwm_hldh)
 124          {
 125   1        u8  xdata *pPWMxHLD;
 126   1        
 127   1        if(PWM_id > PWM15_7)  return FAIL;  //id错误
 128   1        if(pwm_hldh > 1)  return FAIL;  //输出使能错误
 129   1        if(pwm_hldl > 1)  return FAIL;  //输出端的初始电平错误
 130   1        
 131   1        pPWMxHLD = (u8 *)PWMxHLD[PWM_id];
 132   1        *pPWMxHLD = (pwm_hldh << 1) | pwm_hldl;
 133   1        return SUCCESS;
 134   1      }
