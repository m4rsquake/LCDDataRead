  24          //========================================================================
  25          // 函数: Timer0_ISR_Handler
  26          // 描述: Timer0中断函数.
  27          // 参数: none.
  28          // 返回: none.
  29          // 版本: V1.0, 2020-09-23
  30          //========================================================================
  31          void Timer0_ISR_Handler (void) interrupt TIMER0_VECTOR    //进中断时已经清除标志 10KHz 0.1ms
  32          {
  33   1          //COM1事件计时器
  34   1          if(FlagOfCOM1)
  35   1          {
  36   2              Timer0_Count++;
  37   2          }else
  38   1          {
  39   2              Timer0_Count = 0;
  40   2          }
  41   1          
  42   1      //    if(!FlagOfCOM1 && FinishOfADC)         //持续检测COM1高电平
  43   1      //    {
  44   1      //        FinishOfADC = 0;
  45   1      //        ADC_CONTR = (ADC_CONTR & 0xf0) | ADC_START | 0;     //通道0            
  46   1      //    } 
  47   1          if(FlagOfCOM1 && FinishOfADC)                  //检测9个通道
  48   1          {
  49   2              FinishOfADC = 0;
  50   2              switch(Timer0_Count)
  51   2              {
  52   3                  case 20:        //检测到COM1高电平后   20ms后   转化各通道
  53   3                      FlagOfGroup = 0;
  54   3                      ADC_CONTR = (ADC_CONTR & 0xf0) | ADC_START | 1;     //通道1
C51 COMPILER V9.59.0.0   STC8A_TIMER_ISR                                                   12/08/2023 16:39:14 PAGE 2   

  55   3                      break;
  56   3                  case 107:       //再过8.7ms   转化各通道
  57   3                      FlagOfGroup = 1;
  58   3                      ADC_CONTR = (ADC_CONTR & 0xf0) | ADC_START | 1;     //通道1
  59   3                      break;
  60   3                  case 194:       //再过8.7ms   转化各通道
  61   3                      FlagOfGroup = 2;
  62   3                      ADC_CONTR = (ADC_CONTR & 0xf0) | ADC_START | 1;     //通道1
  63   3                      break;
  64   3                  case 294:       //再过10ms   开启COM1的检测
  65   3                      FlagOfCOM1 = 0;
  66   3                      FinishOfADC = 1;
  67   3                      ADC_CONTR = (ADC_CONTR & 0xf0) | ADC_START | 0;     //通道0 
  68   3                      break;
  69   3                  default:
  70   3                      break;
  71   3              }
  72   2          }
  73   1      }
