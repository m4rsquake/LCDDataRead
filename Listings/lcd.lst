 433          void Display_ASCII5X8(unsigned  int x0,unsigned  int y0,unsigned int co,  char *s)
 434          {
 435   1        unsigned char ch = *s;
 436   1        unsigned char dot;
 437   1        int i, j;
 438   1      #define CWIDTH  6
 439   1        while (ch != 0) {
 440   2          if (ch<0x20 || ch > 0x7e) {
 441   3            ch = 0x20;
 442   3          }
 443   2          ch -= 0x20;
 444   2          for (i=0; i<5; i++) {
 445   3            dot = nAsciiDot[ch*5+i];
 446   3            for (j=0; j<8; j++) {
 447   4              if (dot&0x80)Output_Pixel(x0+i, y0+j, co);
 448   4              dot <<= 1;
 449   4            }
 450   3          }
 451   2          x0 += CWIDTH;
 452   2      
 453   2          ch = *++s;
 454   2        }
 455   1      }
