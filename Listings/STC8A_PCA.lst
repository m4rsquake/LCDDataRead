  55          // 函数: void PCALevelSet(u8 PCA_id, u8 PCA_Level)
  56          // 描述: 更新PWM值. 
  57          // 参数: PCA_id: PCA序号. 取值 PCA0,PCA1,PCA2,PCA3
  58          //       PCA_Level: PWM固定输出高电平, 0: 低电平, 1: 高电平.
  59          // 返回: none.
  60          // 版本: V1.0, 2021-6-10
  61          //========================================================================
  62          void  PCALevelSet(u8 PCA_id, u8 PCA_Level)
  63          {
  64   1        if(PCA_id == PCA0)
  65   1        {
  66   2          if(PCA_Level == 1)
  67   2          {
  68   3            PCA_PWM0 &= ~0x32; //PWM固定输出高电平
  69   3            CCAP0H = 0x00;
  70   3          }
  71   2          else
  72   2          {
  73   3            PCA_PWM0 |= 0x32; //PWM固定输出低电平
  74   3            CCAP0H = 0xff;
  75   3          }
  76   2        }
  77   1        else if(PCA_id == PCA1)
  78   1        {
  79   2          if(PCA_Level == 1)
  80   2          {
  81   3            PCA_PWM1 &= ~0x32; //PWM固定输出高电平
  82   3            CCAP1H = 0x00;
  83   3          }
  84   2          else
  85   2          {
  86   3            PCA_PWM1 |= 0x32; //PWM固定输出低电平
  87   3            CCAP1H = 0xff;
  88   3          }
  89   2        }
  90   1        else if(PCA_id == PCA2)
  91   1        {
  92   2          if(PCA_Level == 1)
  93   2          {
  94   3            PCA_PWM2 &= ~0x32; //PWM固定输出高电平
  95   3            CCAP2H = 0x00;
  96   3          }
  97   2          else
  98   2          {
  99   3            PCA_PWM2 |= 0x32; //PWM固定输出低电平
 100   3            CCAP2H = 0xff;
 101   3          }
 102   2        }
 103   1        else if(PCA_id == PCA3)
 104   1        {
 105   2          if(PCA_Level == 1)
 106   2          {
 107   3            PCA_PWM3 &= ~0x32; //PWM固定输出高电平
 108   3            CCAP3H = 0x00;
 109   3          }
 110   2          else
 111   2          {
 112   3            PCA_PWM3 |= 0x32; //PWM固定输出低电平
 113   3            CCAP3H = 0xff;
 114   3          }
 115   2        }
 116   1      }
