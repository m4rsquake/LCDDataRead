 118          //========================================================================
 119          // 函数: void PCA_Init(PCA_id, PCA_InitTypeDef *PCAx)
 120          // 描述: PCA初始化程序.
 121          // 参数: PCA_id: PCA序号. 取值 PCA0,PCA1,PCA2,PCA3,PCA_Counter
 122          //     PCAx: 结构参数,请参考PCA.h里的定义.
 123          // 返回: none.
 124          // 版本: V1.0, 2012-11-22
 125          //========================================================================
 126          void  PCA_Init(u8 PCA_id, PCA_InitTypeDef *PCAx)
 127          {
 128   1        if(PCA_id == PCA_Counter)     //设置公用Counter
 129   1        {
 130   2          CR = 0;
 131   2          CH = 0;
 132   2          CL = 0;
 133   2          CMOD  = (CMOD  & ~(7<<1)) | PCAx->PCA_Clock;      //选择时钟源
 134   2          if(PCAx->PCA_RUN == ENABLE) CR = 1;
 135   2          return;
 136   2        }
 137   1      
 138   1        if(PCA_id == PCA0)
 139   1        {
 140   2          PCA_PWM0  = (PCA_PWM0 & ~(3<<6)) | PCAx->PCA_PWM_Wide;  //PWM宽度
 141   2      
 142   2          PCA_Timer0 = PCAx->PCA_Value;
 143   2          B_Capture0 = 0;
 144   2          CCAP0_tmp = PCA_Timer0;
 145   2          CCAP0L = (u8)CCAP0_tmp;     //将影射寄存器写入捕获寄存器，先写CCAPxL
 146   2          CCAP0H = (u8)(CCAP0_tmp >> 8);  //后写CCAPxH
 147   2        }
 148   1        if(PCA_id == PCA1)
 149   1        {
 150   2          PCA_PWM1  = (PCA_PWM1 & ~(3<<6)) | PCAx->PCA_PWM_Wide;
 151   2      
 152   2          PCA_Timer1 = PCAx->PCA_Value;
 153   2          B_Capture1 = 0;
 154   2          CCAP1_tmp = PCA_Timer1;
 155   2          CCAP1L = (u8)CCAP1_tmp;     //将影射寄存器写入捕获寄存器，先写CCAPxL
 156   2          CCAP1H = (u8)(CCAP1_tmp >> 8);  //后写CCAPxH
 157   2        }
 158   1        if(PCA_id == PCA2)
 159   1        {
 160   2          PCA_PWM2  = (PCA_PWM2 & ~(3<<6)) | PCAx->PCA_PWM_Wide;
 161   2      
 162   2          PCA_Timer2 = PCAx->PCA_Value;
 163   2          B_Capture2 = 0;
 164   2          CCAP2_tmp = PCA_Timer2;
 165   2          CCAP2L = (u8)CCAP2_tmp;     //将影射寄存器写入捕获寄存器，先写CCAPxL
 166   2          CCAP2H = (u8)(CCAP2_tmp >> 8);  //后写CCAPxH
 167   2        }
 168   1        if(PCA_id == PCA3)
 169   1        {
 170   2          PCA_PWM3  = (PCA_PWM3 & ~(3<<6)) | PCAx->PCA_PWM_Wide;
 171   2      
 172   2          PCA_Timer3 = PCAx->PCA_Value;
 173   2          B_Capture3 = 0;
 174   2          CCAP3_tmp = PCA_Timer3;
 175   2          CCAP3L = (u8)CCAP3_tmp;     //将影射寄存器写入捕获寄存器，先写CCAPxL
 176   2          CCAP3H = (u8)(CCAP3_tmp >> 8);  //后写CCAPxH
 177   2        }
 178   1      }
