  13          #include "STC8A_LCM.h"
  14          
  15          //========================================================================
  16          // КЏЪ§: void LCM_Inilize(LCM_InitTypeDef *LCM)
  17          // УшЪі: LCM ГѕЪМЛЏГЬађ.
  18          // ВЮЪ§: LCM: НсЙЙВЮЪ§,ЧыВЮПМLCM.hРяЕФЖЈвх.
  19          // ЗЕЛи: none.
  20          // АцБО: V1.0, 2021-06-02
  21          //========================================================================
  22          void LCM_Inilize(LCM_InitTypeDef *LCM)
  23          {
  24   1        LCMIFSTA = 0x00;
  25   1        if(LCM->LCM_Mode == MODE_M6800)   LCMIFCFG |= MODE_M6800; //LCMНгПкФЃЪНЃКM6800
  26   1        else LCMIFCFG &= ~MODE_M6800; //LCMНгПкФЃЪНЃКI8080
  27   1        
  28   1        if(LCM->LCM_Bit_Wide == BIT_WIDE_16)    LCMIFCFG |= BIT_WIDE_16;  //LCMЪ§ОнПэЖШЃК16ЮЛ
  29   1        else LCMIFCFG &= ~BIT_WIDE_16;  //LCMЪ§ОнПэЖШЃК8ЮЛ
  30   1        
  31   1        if(LCM->LCM_Setup_Time <= 7) LCMIFCFG2 = (LCMIFCFG2 & ~0x1c) | (LCM->LCM_Setup_Time << 2);  //LCMЭЈаХЪ§ОнН
             -ЈСЂЪБМфЃК0~7
  32   1        if(LCM->LCM_Hold_Time <= 3) LCMIFCFG2 = (LCMIFCFG2 & ~0x03) | LCM->LCM_Hold_Time; //LCMЭЈаХЪ§ОнНЈСЂЪБМфЃК
             -0~7
  33   1        
  34   1        if(LCM->LCM_Enable == ENABLE)   LCMIFCR |= 0x80;  //ЪЙФмLCMНгПкЙІФм
  35   1        else LCMIFCR &= ~0x80;  //НћжЙLCMНгПкЙІФм
  36   1      }


