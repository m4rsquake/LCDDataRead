 127          
 128          void OLED_Set_Pos(unsigned char x, unsigned char y)
 129          {
 130   1        OLED_WR_Byte(0xb0+y,OLED_CMD);
 131   1        OLED_WR_Byte((((x+2)&0xf0)>>4)|0x10,OLED_CMD);
 132   1        OLED_WR_Byte(((x+2)&0x0f),OLED_CMD);
 133   1      }
