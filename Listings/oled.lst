 251          //初始化SSD1306
 252          void OLED_Init(void)
 253          {
 254   1      
 255   1        OLED_WR_Byte(0xAE,OLED_CMD);//--display off
 256   1        OLED_WR_Byte(0x02,OLED_CMD);//---set low column address
 257   1        OLED_WR_Byte(0x10,OLED_CMD);//---set high column address
 258   1        OLED_WR_Byte(0x40,OLED_CMD);//--set start line address
 259   1        OLED_WR_Byte(0xB0,OLED_CMD);//--set page address
 260   1        OLED_WR_Byte(0x81,OLED_CMD); // contract control
 261   1        OLED_WR_Byte(0x80,OLED_CMD);//--128
 262   1        OLED_WR_Byte(0xA1,OLED_CMD);//set segment remap
 263   1        OLED_WR_Byte(0xA6,OLED_CMD);//--normal / reverse
 264   1        OLED_WR_Byte(0xA8,OLED_CMD);//--set multiplex ratio(1 to 64)
 265   1        OLED_WR_Byte(0x3F,OLED_CMD);//--1/64 duty
 266   1        OLED_WR_Byte(0xC8,OLED_CMD);//Com scan direction
 267   1        OLED_WR_Byte(0xD3,OLED_CMD);//-set display offset
 268   1        OLED_WR_Byte(0x00,OLED_CMD);//
 269   1      
 270   1        OLED_WR_Byte(0xD5,OLED_CMD);//set osc division
 271   1        OLED_WR_Byte(0x80,OLED_CMD);//
 272   1      
 273   1      //  OLED_WR_Byte(0xD8,OLED_CMD);//set area color mode off
 274   1      //  OLED_WR_Byte(0x05,OLED_CMD);//
 275   1      
 276   1        OLED_WR_Byte(0xD9,OLED_CMD);//Set Pre-Charge Period
 277   1        OLED_WR_Byte(0xF1,OLED_CMD);//Pre-Charge 15 Clocks & Discharge 1 Clock
 278   1      
 279   1        OLED_WR_Byte(0xDA,OLED_CMD);//set com pin configuartion
 280   1        OLED_WR_Byte(0x12,OLED_CMD);//
 281   1      
 282   1        OLED_WR_Byte(0xDB,OLED_CMD);//set Vcomh
 283   1        OLED_WR_Byte(0x30,OLED_CMD);//0.77*Vcc(20H则与SSD1306同为0.77Vcc)
 284   1      
 285   1        OLED_WR_Byte(0x8D,OLED_CMD);//set charge pump enable
 286   1        OLED_WR_Byte(0x14,OLED_CMD);//
 287   1      
 288   1        OLED_WR_Byte(0xAF,OLED_CMD);//--turn on oled panel
 289   1      }
