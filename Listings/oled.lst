 197   1      }
 198          //m^n函数
 199          u32 oled_pow(u8 m,u8 n)
 200          {
 201   1        u32 result=1;
 202   1        while(n--)result*=m;
 203   1        return result;
 204   1      }
 205          //显示2个数字
 206          //x,y :起点坐标
 207          //len :数字的位数
 208          //size:字体大小
 209          //mode:模式 0,填充模式;1,叠加模式
 210          //num:数值(0~4294967295);
 211          void OLED_ShowNum(u8 x,u8 y,u32 num,u8 len,u8 size2)
 212          {
 213   1        u8 t,temp,wide;
 214   1        u8 enshow=0;
 215   1        if(size2==16)wide=8;
 216   1        else wide=6;
 217   1        for(t=0;t<len;t++)
 218   1        {
 219   2          temp=(num/oled_pow(10,len-t-1))%10;
 220   2          if(enshow==0&&t<(len-1))
 221   2          {
 222   3            if(temp==0)
 223   3            {
 224   4              OLED_ShowChar(x+wide*t,y,' ',size2);
 225   4              continue;
 226   4            }else enshow=1;
 227   3      
 228   3          }
 229   2          OLED_ShowChar(x+wide*t,y,temp+'0',size2);
 230   2        }
 231   1      }
 232          //显示一个字符号串
 233          void OLED_ShowString(u8 x,u8 y,u8 *chr,u8 Char_Size)
 234          {
 235   1        unsigned char j=0;
