 336          //========================================================================
 337          // 函数: NVIC_DMA_ADC_Init
 338          // 描述: DMA ADC嵌套向量中断控制器初始化.
 339          // 参数: State:    中断使能状态, ENABLE/DISABLE.
 340          // 参数: Priority: 中断优先级, Priority_0,Priority_1,Priority_2,Priority_3.
 341          // 参数: Bus_Priority: 数据总线访问优先级, Priority_0,Priority_1,Priority_2,Priority_3.
 342          // 返回: 执行结果 SUCCESS/FAIL.
 343          // 版本: V1.0, 2021-05-21
 344          //========================================================================
 345          u8 NVIC_DMA_ADC_Init(u8 State, u8 Priority, u8 Bus_Priority)
 346          {
 347   1        DMA_ADC_CFG &= ~0x0f;
 348   1        if(Priority <= Priority_3) DMA_ADC_CFG |= Priority << 2;
 349   1        if(Bus_Priority <= Priority_3) DMA_ADC_CFG |= Bus_Priority; //数据总线访问优先级
 350   1        if(State == ENABLE)
 351   1          DMA_ADC_CFG |= 0x80;    //bit7 1:Enable Interrupt
 352   1        else
 353   1          DMA_ADC_CFG &= ~0x80;   //bit7 0:Disable Interrupt
 354   1        return SUCCESS;
 355   1      }
