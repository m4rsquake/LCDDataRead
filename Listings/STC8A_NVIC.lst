 300          // 描述: PCA嵌套向量中断控制器初始化.
 301          // 参数: Channel:  通道, PCA0/PCA1/PCA2/PCA_Counter.
 302          // 参数: State:    中断使能状态, PCA_ECOM/PCA_CCAPP/PCA_CCAPN/PCA_MAT/PCA_TOG/PCA_PWM/PCA_ECCF/DISABLE.
C51 COMPILER V9.59.0.0   STC8A_NVIC                                                        12/08/2023 16:39:17 PAGE 6   

 303          // 参数: Priority: 中断优先级, Priority_0,Priority_1,Priority_2,Priority_3.
 304          // 返回: 执行结果 SUCCESS/FAIL.
 305          // 版本: V1.0, 2020-09-29
 306          //========================================================================
 307          u8 NVIC_PCA_Init(u8 Channel, u8 State, u8 Priority)
 308          {
 309   1      //  if(Channel > PCA_Counter) return FAIL;
 310   1        if(Priority <= Priority_3) PCA_Priority(Priority);
 311   1        switch(Channel)
 312   1        {
 313   2          case 0:   //PCA0
 314   2            CCAPM0 = State;
 315   2          break;
 316   2      
 317   2          case 1:   //PCA1
 318   2            CCAPM1 = State;
 319   2          break;
 320   2      
 321   2          case 2:   //PCA2
 322   2            CCAPM2 = State;
 323   2          break;
 324   2      
 325   2          case 3:   //PCA3
 326   2            CCAPM3 = State;
 327   2          break;
 328   2      
 329   2          case 4:   //PCA_Counter
 330   2            CMOD = (CMOD  & ~1) | (State & 1);
 331   2          break;
 332   2        }
 333   1        return SUCCESS;
 334   1      }
